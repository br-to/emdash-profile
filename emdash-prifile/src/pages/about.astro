---
import Base from "../layouts/Base.astro";
import { profile } from "../data/profile";
---

<Base title={`About — ${profile.name}`} description={profile.summary}>
	<article class="about">
		<header class="about-header">
			<h1 class="about-name">{profile.name}</h1>
			<p class="about-role">{profile.role}</p>
		</header>

		<p class="about-summary">{profile.summary}</p>

		<section class="about-section">
			<h2>Skills</h2>
			<ul class="tag-list">
				{profile.skills.map((skill) => <li class="tag">{skill}</li>)}
			</ul>
		</section>

		<section class="about-section">
			<h2>Domains</h2>
			<ul class="tag-list">
				{profile.domains.map((domain) => <li class="tag">{domain}</li>)}
			</ul>
		</section>

		<section class="about-section">
			<h2>Recent Projects</h2>
			<ul class="list">
				{profile.recent_projects.map((project) => <li>{project}</li>)}
			</ul>
		</section>

		<section class="about-section">
			<h2>Contact Topics</h2>
			<ul class="list">
				{profile.contact_topics.map((topic) => <li>{topic}</li>)}
			</ul>
		</section>

		<section class="about-section">
			<h2>Links</h2>
			<ul class="link-list">
				<li><a href={profile.links.blog} target="_blank" rel="noopener noreferrer">Blog (Zenn)</a></li>
				<li><a href={profile.links.x} target="_blank" rel="noopener noreferrer">X (Twitter)</a></li>
				<li><a href={profile.links.github} target="_blank" rel="noopener noreferrer">GitHub</a></li>
			</ul>
		</section>

		<aside class="about-agents-note">
			<p>
				AIエージェント向けには構造化プロフィールデータを
				<code>/agents/profile.json</code> で提供しています（x402 による課金）。
			</p>
		</aside>
	</article>
</Base>

<style>
	.about {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: var(--spacing-16) var(--spacing-6);
	}

	.about-header {
		margin-bottom: var(--spacing-6);
	}

	.about-name {
		font-size: clamp(var(--font-size-2xl), 4vw, var(--font-size-4xl));
		font-weight: 700;
		line-height: var(--leading-tight);
		letter-spacing: var(--tracking-tight);
	}

	.about-role {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
		margin-top: var(--spacing-2);
	}

	.about-summary {
		font-size: var(--font-size-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-text-secondary);
		margin-bottom: var(--spacing-12);
	}

	.about-section {
		margin-bottom: var(--spacing-10);
	}

	.about-section h2 {
		font-size: var(--font-size-sm);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
		margin-bottom: var(--spacing-4);
		padding-bottom: var(--spacing-2);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
		list-style: none;
		padding: 0;
	}

	.tag {
		display: inline-block;
		padding: var(--spacing-1) var(--spacing-3);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		background: var(--color-surface);
		border-radius: var(--radius);
	}

	.list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2);
	}

	.list li {
		padding-left: var(--spacing-4);
		position: relative;
		color: var(--color-text-secondary);
	}

	.list li::before {
		content: "\2014";
		position: absolute;
		left: 0;
		color: var(--color-muted);
	}

	.link-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-4);
	}

	.link-list a {
		color: var(--color-accent);
		text-decoration: none;
		font-size: var(--font-size-base);
		transition: color var(--transition-fast);
	}

	.link-list a:hover {
		color: var(--color-accent-hover);
	}

	.about-agents-note {
		margin-top: var(--spacing-12);
		padding: var(--spacing-4) var(--spacing-6);
		background: var(--color-surface);
		border-radius: var(--radius-lg);
		font-size: var(--font-size-sm);
		color: var(--color-muted);
	}

	.about-agents-note code {
		font-family: var(--font-mono);
		font-size: 0.9em;
		background: var(--color-border-subtle);
		padding: 0.15em 0.3em;
		border-radius: var(--radius);
	}
</style>
